   "id": "b1accc42-aeb8-41f5-80f3-0bedae9c7fb8",
   "metadata": {},
   "outputs": [],
   "source": [
    "x, y = sp.symbols('x y')\n",
    "g = sp.Function('g')(x, y)\n",
    "f = sp.Function('f')(g)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "38985690-25d8-4c35-a963-a32c73087872",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle f{\\left(g{\\left(x,y \\right)} \\right)}$"
      ],
      "text/plain": [
       "f(g(x, y))"
      ]
     },
     "execution_count": 8,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "f"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "29dff5bc-75ea-4879-83b3-3b5836004f36",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle \\frac{\\partial}{\\partial g{\\left(x,y \\right)}} f{\\left(g{\\left(x,y \\right)} \\right)} \\frac{\\partial}{\\partial x} g{\\left(x,y \\right)}$"
      ],
      "text/plain": [
       "Derivative(f(g(x, y)), g(x, y))*Derivative(g(x, y), x)"
      ]
     },
     "execution_count": 9,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "f.diff(x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "f062b66f-4d60-438c-b044-a4b39c4ba669",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle \\frac{\\partial}{\\partial g{\\left(x,y \\right)}} f{\\left(g{\\left(x,y \\right)} \\right)} \\frac{\\partial^{2}}{\\partial x^{2}} g{\\left(x,y \\right)} + \\frac{\\partial^{2}}{\\partial g{\\left(x,y \\right)}^{2}} f{\\left(g{\\left(x,y \\right)} \\right)} \\left(\\frac{\\partial}{\\partial x} g{\\left(x,y \\right)}\\right)^{2}$"
      ],
      "text/plain": [
       "Derivative(f(g(x, y)), g(x, y))*Derivative(g(x, y), (x, 2)) + Derivative(f(g(x, y)), (g(x, y), 2))*Derivative(g(x, y), x)**2"
      ]
     },
     "execution_count": 10,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "f.diff(x, 2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "f0d8ea6e-bd3a-4ae3-aa84-eeb2e1b32e8d",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
